# ── Solana ─────────────────────────────────────────────────────────────────────
# For localnet (default):
SOLANA_CLUSTER=localnet
SOLANA_RPC=http://127.0.0.1:8899
PROGRAM_ID=STRYLKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx1

# For devnet, swap to:
# SOLANA_CLUSTER=devnet
# SOLANA_RPC=https://api.devnet.solana.com

# ── Backend ─────────────────────────────────────────────────────────────────────
PORT=4000
FRONTEND_URL=http://localhost:3000

# ── Gemini AI ──────────────────────────────────────────────────────────────────
# Get a free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── Arweave (production only) ───────────────────────────────────────────────────
# ARWEAVE_WALLET_JSON=<path to arweave wallet JSON>

# ── Frontend (app/.env.local) ─────────────────────────────────────────────────
# VITE_SOLANA_NETWORK=localnet
# VITE_RPC_ENDPOINT=http://127.0.0.1:8899
# VITE_PROGRAM_ID=STRYLKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx1
# VITE_BACKEND_URL=http://localhost:4000
